---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => +b.data.pubDate - +a.data.pubDate);
---
<BaseLayout title="Журнал BANKAY — активы простыми словами" description="Статьи BANKAY: как работают ретинол, ниацинамид и другие активы — понятно и без сложных слов.">
  <div class="shell">
    <h1>Журнал</h1>
    <p class="sub">Коротко о том, как работают активы — и как не навредить коже.</p>
    <div class="list">
      {posts.map((p) => (
        <a class="post" href={`/blog/${p.id}/`}>
          <span class="tag">Активы</span>
          <h2>{p.data.title}</h2>
          <p>{p.data.description}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  h1{ font:400 38px/1.2 Georgia,serif; margin:36px 0 8px }
  .sub{ color:var(--muted); font-size:14px; margin:0 0 30px }
  .list{ display:grid; grid-template-columns:1fr 1fr; gap:20px }
  .post{ background:var(--card); border:1px solid var(--ring); border-radius:var(--radius);
    padding:26px; text-decoration:none; display:block }
  .post:hover h2,.post:focus h2{ color:var(--copper) }
  .post .tag{ font-size:11px; letter-spacing:.16em; text-transform:uppercase; color:var(--copper) }
  .post h2{ font:400 22px/1.3 Georgia,serif; margin:10px 0 8px }
  .post p{ color:var(--muted); font-size:14px; margin:0 }
  @media (max-width:700px){ .list{ grid-template-columns:1fr } }
</style>
