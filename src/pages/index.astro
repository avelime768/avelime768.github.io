---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => +b.data.pubDate - +a.data.pubDate);
---
<BaseLayout title="BANKAY — уход, который понятен" description="BANKAY: активы для кожи без похода к косметологу. Понятно, эстетично, доказательно. Разбираем ретинол, ниацинамид, кислоты — и как ими пользоваться.">
  <h1>BANKAY — активы без косметолога</h1>
  <p>Разбираем уход просто: что за актив, зачем коже и как применять. Эстетично, понятно, доказательно.</p>
  <h2>Последние статьи</h2>
  <ul>
    {posts.map((p) => (
      <li><a href={`/blog/${p.id}/`}>{p.data.title}</a></li>
    ))}
  </ul>
</BaseLayout>
